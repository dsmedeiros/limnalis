{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limnalis.local/schema/v0.2.2/conformance-result.json",
  "title": "Limnalis v0.2.2 conformance-result schema",
  "$defs": {
    "TruthValue": {
      "type": "string",
      "enum": [
        "T",
        "F",
        "B",
        "N"
      ]
    },
    "SupportValue": {
      "type": "string",
      "enum": [
        "supported",
        "partial",
        "conflicted",
        "absent",
        "inapplicable"
      ]
    },
    "EvalSnapshot": {
      "type": "object",
      "properties": {
        "truth": {
          "type": "string",
          "enum": [
            "T",
            "F",
            "B",
            "N"
          ]
        },
        "reason": {
          "type": "string"
        },
        "support": {
          "type": "string",
          "enum": [
            "supported",
            "partial",
            "conflicted",
            "absent",
            "inapplicable"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "provenance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "truth"
      ]
    },
    "PerEvaluatorEvalMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/EvalSnapshot"
      }
    },
    "ClaimLicenseExpectation": {
      "type": "object",
      "properties": {
        "overall": {
          "$ref": "#/$defs/EvalSnapshot"
        },
        "individual": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/EvalSnapshot"
          }
        },
        "joint": {
          "$ref": "#/$defs/EvalSnapshot"
        }
      },
      "additionalProperties": false
    },
    "ClaimExpectation": {
      "type": "object",
      "properties": {
        "per_evaluator": {
          "$ref": "#/$defs/PerEvaluatorEvalMap"
        },
        "aggregate": {
          "$ref": "#/$defs/EvalSnapshot"
        },
        "license": {
          "$ref": "#/$defs/ClaimLicenseExpectation"
        }
      },
      "additionalProperties": false,
      "minProperties": 1,
      "allOf": [
        {
          "if": {
            "required": [
              "aggregate"
            ]
          },
          "then": {
            "required": [
              "per_evaluator"
            ]
          }
        }
      ]
    },
    "BlockExpectation": {
      "type": "object",
      "properties": {
        "per_evaluator": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "enum": [
              "T",
              "F",
              "B",
              "N"
            ]
          }
        },
        "aggregate": {
          "type": "string",
          "enum": [
            "T",
            "F",
            "B",
            "N"
          ]
        },
        "claimIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "per_evaluator",
        "aggregate"
      ]
    },
    "TransportExpectation": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "metadata_only",
            "preserved",
            "degraded",
            "transported",
            "blocked",
            "unresolved",
            "pattern_only"
          ]
        },
        "sourceAggregate": {
          "$ref": "#/$defs/EvalSnapshot"
        },
        "dstAggregate": {
          "$ref": "#/$defs/EvalSnapshot"
        },
        "per_evaluator": {
          "$ref": "#/$defs/PerEvaluatorEvalMap"
        }
      },
      "additionalProperties": false,
      "required": [
        "status"
      ]
    },
    "StepExpectation": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "claims": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ClaimExpectation"
          }
        },
        "blocks": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/BlockExpectation"
          }
        },
        "transports": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/TransportExpectation"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "id"
      ]
    },
    "SessionExpectation": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StepExpectation"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "steps"
      ]
    },
    "DiagnosticExpectation": {
      "type": "object",
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "subject": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "severity",
        "code"
      ]
    },
    "AdequacyExpectation": {
      "type": "object",
      "properties": {
        "truth": {
          "type": "string",
          "enum": [
            "T",
            "F",
            "B",
            "N"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "truth"
      ]
    },
    "ExpectedResult": {
      "type": "object",
      "properties": {
        "baseline_states": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "ready",
              "deferred",
              "unresolved"
            ]
          }
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SessionExpectation"
          }
        },
        "adequacy_expectations": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/AdequacyExpectation"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DiagnosticExpectation"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "sessions",
        "diagnostics"
      ]
    }
  },
  "$ref": "#/$defs/ExpectedResult"
}