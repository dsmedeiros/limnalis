{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limnalis.local/schema/v0.2.2/fixture-corpus.json",
  "title": "Limnalis v0.2.2 fixture corpus schema",
  "type": "object",
  "$defs": {
    "TruthValue": {
      "type": "string",
      "enum": [
        "T",
        "F",
        "B",
        "N"
      ]
    },
    "SupportValue": {
      "type": "string",
      "enum": [
        "supported",
        "partial",
        "conflicted",
        "absent",
        "inapplicable"
      ]
    },
    "EvalSnapshot": {
      "type": "object",
      "properties": {
        "truth": {
          "type": "string",
          "enum": [
            "T",
            "F",
            "B",
            "N"
          ]
        },
        "reason": {
          "type": "string"
        },
        "support": {
          "type": "string",
          "enum": [
            "supported",
            "partial",
            "conflicted",
            "absent",
            "inapplicable"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "provenance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "truth"
      ]
    },
    "PerEvaluatorEvalMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/EvalSnapshot"
      }
    },
    "ClaimLicenseExpectation": {
      "type": "object",
      "properties": {
        "overall": {
          "$ref": "#/$defs/EvalSnapshot"
        },
        "individual": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/EvalSnapshot"
          }
        },
        "joint": {
          "$ref": "#/$defs/EvalSnapshot"
        }
      },
      "additionalProperties": false
    },
    "ClaimExpectation": {
      "type": "object",
      "properties": {
        "per_evaluator": {
          "$ref": "#/$defs/PerEvaluatorEvalMap"
        },
        "aggregate": {
          "$ref": "#/$defs/EvalSnapshot"
        },
        "license": {
          "$ref": "#/$defs/ClaimLicenseExpectation"
        }
      },
      "additionalProperties": false,
      "minProperties": 1,
      "allOf": [
        {
          "if": {
            "required": [
              "aggregate"
            ]
          },
          "then": {
            "required": [
              "per_evaluator"
            ]
          }
        }
      ]
    },
    "BlockExpectation": {
      "type": "object",
      "properties": {
        "per_evaluator": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "enum": [
              "T",
              "F",
              "B",
              "N"
            ]
          }
        },
        "aggregate": {
          "type": "string",
          "enum": [
            "T",
            "F",
            "B",
            "N"
          ]
        },
        "claimIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "per_evaluator",
        "aggregate"
      ]
    },
    "TransportExpectation": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "metadata_only",
            "preserved",
            "degraded",
            "transported",
            "blocked",
            "unresolved",
            "pattern_only"
          ]
        },
        "sourceAggregate": {
          "$ref": "#/$defs/EvalSnapshot"
        },
        "dstAggregate": {
          "$ref": "#/$defs/EvalSnapshot"
        },
        "per_evaluator": {
          "$ref": "#/$defs/PerEvaluatorEvalMap"
        }
      },
      "additionalProperties": false,
      "required": [
        "status"
      ]
    },
    "StepExpectation": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "claims": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ClaimExpectation"
          }
        },
        "blocks": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/BlockExpectation"
          }
        },
        "transports": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/TransportExpectation"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "id"
      ]
    },
    "SessionExpectation": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StepExpectation"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "steps"
      ]
    },
    "DiagnosticExpectation": {
      "type": "object",
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "subject": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "severity",
        "code"
      ]
    },
    "AdequacyExpectation": {
      "type": "object",
      "properties": {
        "truth": {
          "type": "string",
          "enum": [
            "T",
            "F",
            "B",
            "N"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "truth"
      ]
    },
    "ExpectedResult": {
      "type": "object",
      "properties": {
        "baseline_states": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "ready",
              "deferred",
              "unresolved"
            ]
          }
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SessionExpectation"
          }
        },
        "adequacy_expectations": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/AdequacyExpectation"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DiagnosticExpectation"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "sessions",
        "diagnostics"
      ]
    },
    "FrameNode": {
      "type": "object",
      "properties": {
        "node": {
          "const": "Frame"
        },
        "system": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "scale": {
          "type": "string"
        },
        "task": {
          "type": "string"
        },
        "regime": {
          "type": "string"
        },
        "observer": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "facetPolicy": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "node",
        "system",
        "namespace",
        "scale",
        "task",
        "regime"
      ]
    },
    "FramePatternNode": {
      "type": "object",
      "properties": {
        "node": {
          "const": "FramePattern"
        },
        "facets": {
          "$ref": "#/$defs/FacetValueMap"
        },
        "facetPolicy": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "node",
        "facets"
      ]
    },
    "FrameOrPatternNode": {
      "oneOf": [
        {
          "$ref": "#/$defs/FrameNode"
        },
        {
          "$ref": "#/$defs/FramePatternNode"
        }
      ]
    },
    "TimeCtxNode": {
      "type": "object",
      "properties": {
        "node": {
          "const": "TimeCtx"
        },
        "kind": {
          "type": "string",
          "enum": [
            "point",
            "interval",
            "window"
          ]
        },
        "t": {
          "type": "string"
        },
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        },
        "lag": {
          "type": "string"
        },
        "step": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "node",
        "kind"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "point"
              }
            }
          },
          "then": {
            "required": [
              "t"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "interval",
                  "window"
                ]
              }
            }
          },
          "then": {
            "required": [
              "start",
              "end"
            ]
          }
        }
      ]
    },
    "FacetValueMap": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "scale": {
          "type": "string"
        },
        "task": {
          "type": "string"
        },
        "regime": {
          "type": "string"
        },
        "observer": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "FrameCompletion": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "scale": {
          "type": "string"
        },
        "task": {
          "type": "string"
        },
        "regime": {
          "type": "string"
        },
        "observer": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "system",
        "namespace",
        "scale",
        "task",
        "regime"
      ]
    },
    "FixtureTimeSpec": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "point",
            "interval",
            "window"
          ]
        },
        "t": {
          "type": "string"
        },
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        },
        "lag": {
          "type": "string"
        },
        "step": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "point"
              }
            }
          },
          "then": {
            "required": [
              "t"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "interval",
                  "window"
                ]
              }
            }
          },
          "then": {
            "required": [
              "start",
              "end"
            ]
          }
        }
      ]
    },
    "TransportQuery": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "claimId": {
          "type": "string"
        },
        "bridgeId": {
          "type": "string"
        },
        "dstCompletion": {
          "type": "object",
          "required": [
            "facets"
          ],
          "properties": {
            "facets": {
              "$ref": "#/$defs/FacetValueMap"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "claimId",
        "bridgeId"
      ]
    },
    "EnvironmentSession": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "shared_state": {
          "type": "boolean"
        },
        "base_frame": {
          "$ref": "#/$defs/FrameOrPatternNode"
        },
        "base_time": {
          "$ref": "#/$defs/FixtureTimeSpec"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "time": {
                "$ref": "#/$defs/FixtureTimeSpec"
              },
              "history_binding": {
                "type": "string"
              },
              "frame_override": {
                "$ref": "#/$defs/FrameOrPatternNode"
              },
              "claim_subset": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "transport_queries": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/TransportQuery"
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "id"
            ]
          },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "steps"
      ]
    },
    "CaseEnvironment": {
      "type": "object",
      "properties": {
        "frame_resolver": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "bundle_frame_completion": {
                  "$ref": "#/$defs/FrameCompletion"
                }
              },
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        },
        "transport_queries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TransportQuery"
          }
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EnvironmentSession"
          }
        }
      },
      "additionalProperties": false
    },
    "FixtureDefinition": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "evaluator_binding",
            "criterion_binding",
            "evidence_policy",
            "bridge_binding",
            "baseline_source",
            "adequacy_method",
            "resolution_binding",
            "data_fixture"
          ]
        },
        "behavior": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            },
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        },
        "used_by": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "behavior",
        "used_by"
      ]
    },
    "AstDecision": {
      "type": "object",
      "properties": {
        "topic": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "settled",
            "open",
            "draft"
          ]
        },
        "canonical_shape": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            },
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        },
        "validation": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            },
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        },
        "corpus_support": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            },
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "topic",
        "status"
      ]
    },
    "ConformanceCase": {
      "type": "object",
      "properties": {
        "track": {
          "type": "string",
          "enum": [
            "A",
            "B"
          ]
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "focus": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "source": {
          "type": "string"
        },
        "environment": {
          "$ref": "#/$defs/CaseEnvironment"
        },
        "normalized_ast_expectations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "expected": {
          "$ref": "#/$defs/ExpectedResult"
        }
      },
      "additionalProperties": false,
      "required": [
        "track",
        "id",
        "name",
        "focus",
        "source",
        "normalized_ast_expectations",
        "expected"
      ]
    }
  },
  "required": [
    "version",
    "meta",
    "ast_decisions",
    "fixtures",
    "cases"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "phase_order": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "purpose",
        "phase_order"
      ]
    },
    "ast_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AstDecision"
      }
    },
    "fixtures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/FixtureDefinition"
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ConformanceCase"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "$comment": "This schema validates the machine-readable fixture corpus. Semantic checks such as matching exact joint-adequacy anchor sets and evaluator-membership consistency require evaluator-level validation in addition to JSON Schema."
}