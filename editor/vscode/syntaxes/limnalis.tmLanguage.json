{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Limnalis",
  "scopeName": "source.limnalis",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#inline-patterns" },
    { "include": "#inline-lists" },
    { "include": "#keywords-control" },
    { "include": "#keywords-operator" },
    { "include": "#type-names" },
    { "include": "#punctuation-block" },
    { "include": "#punctuation-terminator" },
    { "include": "#atoms" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.hash.limnalis",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.limnalis",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.limnalis",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.limnalis",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "inline-patterns": {
      "patterns": [
        {
          "name": "constant.other.pattern.limnalis",
          "match": "@\\{[^{}]*\\}"
        }
      ]
    },
    "inline-lists": {
      "patterns": [
        {
          "name": "meta.bracket.square.limnalis",
          "begin": "\\[",
          "end": "\\]",
          "patterns": [
            { "include": "#strings" },
            { "include": "#atoms" }
          ]
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.limnalis",
          "match": "\\b(bundle|frame|evaluator|baseline|anchor|fictional_anchor|bridge|local|systemic|meta|evidence_relation|evidence|resolution_policy|joint_adequacy|session|step|judged_by|transport|claims)\\b"
        }
      ]
    },
    "keywords-operator": {
      "patterns": [
        {
          "name": "keyword.operator.limnalis",
          "match": "\\b(AND|OR|IMPLIES|IFF|declare|as|within)\\b"
        },
        {
          "name": "keyword.operator.causal.limnalis",
          "match": "=>\\[[^\\]]*\\]"
        }
      ]
    },
    "type-names": {
      "patterns": [
        {
          "name": "entity.name.type.limnalis",
          "match": "\\b(idealization|placeholder|proxy|aggregate|point|set|manifold|moving|fixed|on_reference|tracked|single|paraconsistent_union|priority_order|adjudicated|primary|adversarial|audit|auxiliary)\\b"
        }
      ]
    },
    "punctuation-block": {
      "patterns": [
        {
          "name": "punctuation.section.block.limnalis",
          "match": "[{}]"
        }
      ]
    },
    "punctuation-terminator": {
      "patterns": [
        {
          "name": "punctuation.terminator.limnalis",
          "match": ";"
        }
      ]
    },
    "atoms": {
      "patterns": [
        {
          "name": "constant.numeric.limnalis",
          "match": "\\b-?\\d+(\\.\\d+)?\\b"
        },
        {
          "name": "variable.other.limnalis",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
